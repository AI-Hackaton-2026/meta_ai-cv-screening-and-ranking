# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Claude model (defaults to claude-sonnet-4-5)
CLAUDE_MODEL=claude-sonnet-4-5

# Max concurrent CV scoring tasks (default 5)
MAX_CONCURRENCY=5

# Allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./data/metahire.db

# Optional: persist original CV files in a private Supabase Storage bucket.
# Use the project root URL, for example: https://your-project-ref.supabase.co
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cvs

# Optional: Mailjet transactional email for interview invitations.
# EMAIL_FROM must be a verified Mailjet sender address.
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=MetaHire
EMAIL_REPLY_TO=
