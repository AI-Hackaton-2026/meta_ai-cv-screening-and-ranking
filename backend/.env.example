# Copy this file to .env and fill in your values.

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Claude model (defaults to claude-sonnet-4-5)
CLAUDE_MODEL=claude-sonnet-4-5

# Max concurrent CV scoring tasks (default 5)
MAX_CONCURRENCY=5

# Allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173

# Database URL (Supabase session pooler):
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# Local dev only (corporate SSL proxy). Omit or false on Render/production.
DATABASE_SSL_INSECURE=false

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cvs

MAILJET_API_KEY=
MAILJET_SECRET_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=MetaHire
EMAIL_REPLY_TO=
